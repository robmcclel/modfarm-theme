{
  "apiVersion": 2,
  "name": "modfarm/site-background",
  "title": "Page Background (Inline Style)",
  "description": "Set a page background via a generated <style> tag (same behavior as the core HTML block).",
  "category": "design",
  "icon": "art",
  "keywords": ["background", "page", "style", "gradient", "image", "color"],
  "supports": { "align": false, "html": false, "multiple": false },
  "attributes": {
    "mode":                 { "type": "string", "default": "color" },

    "color":                { "type": "string", "default": "" },
    "bgOpacity":            { "type": "number", "default": 1 },

    "gradientAngle":        { "type": "number", "default": 180 },
    "gradientStartColor":   { "type": "string", "default": "" },
    "gradientEndColor":     { "type": "string", "default": "" },
    "gradientStartPos":     { "type": "number", "default": 0 },
    "gradientEndPos":       { "type": "number", "default": 100 },

    "image":                { "type": "object", "default": { "id": 0, "url": "" } },
    "size":                 { "type": "string", "default": "cover" },
    "position":             { "type": "string", "default": "center center" },
    "repeat":               { "type": "string", "default": "no-repeat" },
    "attachment":           { "type": "string", "default": "scroll" },
    "overlayColor":         { "type": "string", "default": "" },
    "overlayOpacity":       { "type": "number", "default": 0 },

    "textColor":            { "type": "string", "default": "" },
    "linkColor":            { "type": "string", "default": "" }
  },
  "editorScript": "modfarm-site-background-editor",
  "style": "file:./style.css",
  "editorStyle": "file:./editor.css"
}