{
  "apiVersion": 3,
  "name": "modfarm/hero-cover",
  "title": "Hero Cover",
  "category": "modfarm-theme",
  "icon": "cover-image",
  "description": "Full-width hero background (Book hero image / Taxonomy archive image) with inner blocks.",
  "textdomain": "modfarm",
  "supports": {
    "html": false,
    "align": ["full", "wide"]
  },
  "attributes": {
    "mode": { "type": "string", "default": "auto" },
    "manualUrl": { "type": "string", "default": "" },

    "bookMetaKey": { "type": "string", "default": "hero_image" },
    "termMetaKey": { "type": "string", "default": "archive_hero_image" },

    "fallbackFeatured": { "type": "boolean", "default": true },

    "minHeight": { "type": "number", "default": 420 },
    "dimRatio": { "type": "number", "default": 20 },
    "overlayColor": { "type": "string", "default": "#000000" },
    "overlayGradient": { "type": "string", "default": "" },

    "contentMaxWidth": { "type": "string", "default": "1200px" },
    "contentAlign": { "type": "string", "default": "center" }
  },
  "usesContext": ["postId", "postType"],
  "editorScript": ["modfarm-editor-deps", "modfarm-hero-cover-editor"],
  "style": "file:./style.css",
  "editorStyle": "file:./editor.css"
}