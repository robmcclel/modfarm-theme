{
  "apiVersion": 2,
  "name": "modfarm/theme-icon",
  "title": "Theme Icon",
  "category": "modfarm-theme",
  "icon": "format-image",
  "description": "Display the Site Icon (favicon) anywhere, with optional override.",
  "keywords": ["icon", "site icon", "favicon", "brand"],
  "supports": {
    "html": false,
    "align": false
  },
  "attributes": {
    "size": { "type": "number", "default": 48 },
    "shape": { "type": "string", "enum": ["square", "rounded", "circle"], "default": "square" },
    "linkHome": { "type": "boolean", "default": true },
    "overrideImageID": { "type": "number", "default": 0 },
    "overrideImageURL": { "type": "string", "default": "" },
    "alt": { "type": "string", "default": "" },
    "className": { "type": "string", "default": "" },
    "displayMode": { "type": "string", "enum": ["inline", "block"], "default": "block" },
    "align": { "type": "string", "enum": ["left", "center", "right"], "default": "center" }
  },
  "editorScript": "modfarm-theme-icon-editor",
  "style": "file:./style.css",
  "editorStyle": "file:./editor.css"
}