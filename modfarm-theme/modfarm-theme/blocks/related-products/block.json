{
  "apiVersion": 3,
  "name": "modfarm/related-products",
  "title": "Related Products",
  "description": "Displays related Store Offers using the Theme Product Card.",
  "category": "modfarm-store",
  "icon": "screenoptions",
  "keywords": ["offer", "related", "products", "store", "modfarm"],
  "usesContext": ["postId", "postType"],
  "attributes": {
    "offerId": { "type": "number", "default": 0 },
    "heading": { "type": "string", "default": "Related Products" },
    "showHeading": { "type": "boolean", "default": true },
    "taxonomy": { "type": "string", "default": "" },
    "manualIds": { "type": "array", "default": [] },
    "productsPerPage": { "type": "number", "default": 3 },
    "columns": { "type": "number", "default": 3 },
    "cardLayout": { "type": "string", "default": "commerce" },
    "imageAspect": { "type": "string", "default": "1 / 1" },
    "showTitle": { "type": "boolean", "default": false },
    "showExcerpt": { "type": "boolean", "default": false },
    "showDetails": { "type": "boolean", "default": true },
    "showPrimaryButton": { "type": "boolean", "default": true },
    "showSecondaryButton": { "type": "boolean", "default": true },
    "detailMode": { "type": "string", "default": "auto" },
    "detailOverride": { "type": "string", "default": "" },
    "primaryButtonLabel": { "type": "string", "default": "Buy Now" },
    "secondaryButtonLabel": { "type": "string", "default": "Learn More" },
    "secondaryButtonLink": { "type": "string", "default": "permalink" },
    "buttonStyleMode": { "type": "string", "default": "inherit" },
    "buttonLayout": { "type": "string", "default": "joined" },
    "buttonCorners": { "type": "string", "default": "square" },
    "primaryButtonBg": { "type": "string", "default": "" },
    "primaryButtonFg": { "type": "string", "default": "" },
    "primaryButtonBorder": { "type": "string", "default": "" },
    "secondaryButtonBg": { "type": "string", "default": "" },
    "secondaryButtonFg": { "type": "string", "default": "" },
    "secondaryButtonBorder": { "type": "string", "default": "" }
  },
  "editorScript": "modfarm-related-products-editor",
  "style": "file:./style.css",
  "editorStyle": "file:./editor.css",
  "supports": {
    "html": false,
    "align": ["wide", "full"]
  }
}
