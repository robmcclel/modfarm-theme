{
  "apiVersion": 2,
  "name": "modfarm/multi-tax-format",
  "title": "Multi-Tax Book Block",
  "category": "modfarm-theme",
  "icon": "book",
  "description": "Display books by selected taxonomy (series, genre, author, etc.) with optional filters and custom layout.",
  "keywords": ["Multi Tax", "Book Format", "Book Grid"],
  "supports": {
    "html": false,
    "align": false
  },
  "attributes": {
   
    "tax-type":        { "type": "string",  "default": "" },
    "series-select":   { "type": "object",  "default": { "id": 0 } },
    "genre-select":    { "type": "object",  "default": { "id": 0 } },
    "bookauthor-select": { "type": "object", "default": { "id": 0 } },
    "language-select": { "type": "object",  "default": { "id": 0 } },
    "booktag-select":  { "type": "object",  "default": { "id": 0 } },

    "book-format":     { "type": "object",  "default": { "id": 0 } },

    "image-type":      { "type": "string",  "default": "featured" },

    "books-in-row":    { "type": "string",  "default": "25%" },
    "display-layout":  { "type": "string",  "default": "grid" },
    "horizontal-columns": { "type": "number", "default": 4 },
    "display-order":   { "type": "string",  "default": "DESC" },
    "books-per-page":  { "type": "number",  "default": 12 },
    "show-pagination": { "type": "boolean", "default": false },

    
    "button-text":     { "type": "string",  "default": "See The Book" },
    "button-link":     { "type": "string",  "default": "bookpage" },
    "button-target":   { "type": "string",  "default": "_self" },
    "tracker-loc":     { "type": "string",  "default": "" },
    "volume-text":     { "type": "string",  "default": "Book" },

    "samplebtn-text":  { "type": "string",  "default": "Play Sample" },

    
    "cardUseGlobal":          { "type": "boolean", "default": true },

   
    "cardShowTitle":          { "type": "boolean", "default": true },
    "cardShowSeries":         { "type": "boolean", "default": true },
    "cardShowPrimaryButton":  { "type": "boolean", "default": true },
    "cardShowSampleButton":   { "type": "boolean", "default": true },

    
    "cardCoverShape":         { "type": "string",  "default": "inherit" },   
    "cardButtonShape":        { "type": "string",  "default": "inherit" },   
    "cardSampleShape":        { "type": "string",  "default": "inherit" },   
    "cardCtaMode":            { "type": "string",  "default": "inherit" },   
    "cardShadowStyle":        { "type": "string",  "default": "inherit" },  

    
    "cardButtonBg":           { "type": "string",  "default": "" },
    "cardButtonFg":           { "type": "string",  "default": "" },
    "cardSampleBg":           { "type": "string",  "default": "" },
    "cardSampleFg":           { "type": "string",  "default": "" }
  },
  "editorScript": "modfarm-multi-tax-format-editor",
  "style": "file:./assets/css/book-cards.css",
  "editorStyle": "file:./assets/css/book-cards.css"
}
