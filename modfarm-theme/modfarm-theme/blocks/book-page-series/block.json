{
  "apiVersion": 2,
  "name": "modfarm/book-page-series",
  "title": "Book Page Series",
  "category": "modfarm-book-page",
  "icon": "book",
  "description": "Displays the series information for a book, including position or a custom label.",
  "supports": {
    "html": false
  },
  "attributes": {
    "displayMode": {
      "type": "string",
      "default": "auto"
    },
    "volumeLabel": {
      "type": "string",
      "default": "Book"
    },
    "customLabel": {
      "type": "string",
      "default": ""
    },
    "alignment": {
      "type": "string",
      "default": "left"
    },
    "fontSize": {
      "type": "number",
      "default": 16
    },
    "textColor": {
      "type": "string",
      "default": ""
    }
  },
  "editorScript": "modfarm-book-page-series-editor",
  "style": "file:./style.css",
  "editorStyle": "file:./editor.css"
}