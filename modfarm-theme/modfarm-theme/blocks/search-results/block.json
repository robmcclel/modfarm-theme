{
  "apiVersion": 2,
  "name": "modfarm/search-results",
  "title": "Search Results",
  "category": "modfarm-theme",
  "icon": "search",
  "description": "Renders grouped site search results for books, posts, authors, and series.",
  "keywords": ["search", "books", "authors", "series"],
  "supports": {
    "html": false,
    "anchor": true
  },
  "attributes": {
    "booksLimit": { "type": "number", "default": 8 },
    "postsLimit": { "type": "number", "default": 8 },
    "termsLimit": { "type": "number", "default": 6 },
    "showBooks": { "type": "boolean", "default": true },
    "showPosts": { "type": "boolean", "default": true },
    "showAuthors": { "type": "boolean", "default": true },
    "showSeries": { "type": "boolean", "default": true },
    "bookCoverSource": { "type": "string", "default": "cover_ebook" }
  },
  "editorScript": "modfarm-search-results-editor",
  "style": "file:./style.css",
  "editorStyle": "file:./style.css"
}
