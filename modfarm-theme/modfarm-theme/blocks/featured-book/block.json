{
  "apiVersion": 2,
  "name": "modfarm/featured-book",
  "title": "Featured Book",
  "category": "modfarm-book-page",
  "icon": "book",
  "description": "Feature a book with cover art, description, and up to three buttons from BMS fields.",
  "attributes": {
    "mode":        { "type": "string",  "default": "manual" },
    "dateType":    { "type": "string",  "default": "publication_date" },
    "pinnedId":    { "type": "number",  "default": 0 },

    "bookId":       { "type": "number",  "default": 0 },
    "coverSource":  { "type": "string",  "default": "cover_ebook" },
    "coverCorners": { "type": "string",  "default": "square" },

    "followBookText": { "type": "boolean", "default": true },

    "kicker":       { "type": "string",  "default": "" },
    "headline":     { "type": "string",  "default": "" },
    "subhead":      { "type": "string",  "default": "" },

    "descOverride": { "type": "string",  "default": "" },
    "useCustomDesc": { "type": "boolean", "default": false },
    "refreshCustomDescOnBookChange": { "type": "boolean", "default": false },
    "useExcerpt":   { "type": "boolean", "default": true },
    "excerptLen":   { "type": "number",  "default": 180 },

    "btn1Source":  { "type": "string",  "default": "kindle_url" },
    "btn1Label":   { "type": "string",  "default": "Buy Now" },
    "btn1Variant": { "type": "string",  "default": "primary" },

    "btn2Source":  { "type": "string",  "default": "permalink" },
    "btn2Label":   { "type": "string",  "default": "See The Book" },
    "btn2Variant": { "type": "string",  "default": "outline" },

    "btn3Source":  { "type": "string",  "default": "__none__" },
    "btn3Label":   { "type": "string",  "default": "" },
    "btn3Variant": { "type": "string",  "default": "outline" },

    "buttonStyleMode":  { "type": "string", "default": "inherit" },
    "buttonRadiusMode": { "type": "string", "default": "inherit" },

    "btnPrimaryBg":     { "type": "string", "default": "" },
    "btnPrimaryText":   { "type": "string", "default": "" },
    "btnPrimaryBorder": { "type": "string", "default": "" },

    "btnOutlineBg":     { "type": "string", "default": "" },
    "btnOutlineText":   { "type": "string", "default": "" },
    "btnOutlineBorder": { "type": "string", "default": "" },

    "darkHero":      { "type": "boolean", "default": false },
    "mediaSide":     { "type": "string",  "default": "left" },

    "buttonCorners": { "type": "string",  "default": "square" },
    "tracking":      { "type": "boolean", "default": false }
  },
  "supports": {
    "html": false,
    "anchor": true
  },
  "editorScript": "modfarm-featured-book-editor",
  "style": "file:./style.css",
  "editorStyle": "file:./style.css"
}