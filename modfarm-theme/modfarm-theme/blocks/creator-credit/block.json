{
  "apiVersion": 2,
  "name": "modfarm/creator-credit",
  "title": "Creator Credit",
  "category": "modfarm-theme",
  "icon": "groups",
  "description": "Show a single taxonomy term (Author, Artist, etc.) from the current Book. Auto layout, theme-aware colors, adjustable image size.",
  "keywords": ["creator", "credit", "taxonomy", "people"],
  "supports": { "html": false, "align": false },
  "attributes": {
    "heading":       { "type": "string",  "default": "" },
    "taxonomy":      { "type": "string",  "default": "book-author" },
    "customTax":     { "type": "string",  "default": "" },
    "termId": { "type": "number", "default": 0 },
    "layout":        { "type": "string",  "default": "auto" },   
    "imageShape":    { "type": "string",  "default": "circle" }, 
    "imgSize":       { "type": "number",  "default": 240 },     

    "linkToArchive": { "type": "boolean", "default": true },
    "showDescription": { "type": "boolean", "default": true },
    "hideIfEmpty":   { "type": "boolean", "default": false },

    "accentColor":   { "type": "string",  "default": "" },
    "textColor":     { "type": "string",  "default": "" }
  },
  "editorScript": "modfarm-creator-credit-editor",
  "style": "file:./style.css",
  "editorStyle": "file:./style.css"
}