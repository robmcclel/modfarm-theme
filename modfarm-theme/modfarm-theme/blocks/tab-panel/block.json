{
  "apiVersion": 2,
  "name": "modfarm/tab-panel",
  "title": "Tab Panel",
  "category": "modfarm-theme",
  "icon": "excerpt-view",
  "description": "A single tab inside Simple Tabs. Add any blocks inside.",
  "parent": ["modfarm/simple-tabs"],
  "supports": {
    "html": false,
    "reusable": false
