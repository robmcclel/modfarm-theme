{
  "apiVersion": 2,
  "name": "modfarm/interview-qa",
  "title": "Interview Q&A",
  "category": "modfarm-theme",
  "icon": "format-chat",
  "description": "Repeatable interview question and answer pairs with optional author profile data and structured data output.",
  "keywords": ["interview", "qa", "questions", "author"],
  "supports": { "html": false, "align": ["wide", "full"] },
  "attributes": {
    "items": { "type": "array", "default": [] },
    "authorId": { "type": "number", "default": 0 },
    "authorTaxonomy": { "type": "string", "default": "book-author" },
    "showAuthorProfile": { "type": "boolean", "default": false },
    "showAuthorImage": { "type": "boolean", "default": true },
    "showAuthorBio": { "type": "boolean", "default": true },
    "showAuthorSocials": { "type": "boolean", "default": true },
    "emitStructuredData": { "type": "boolean", "default": true },
    "heading": { "type": "string", "default": "" },
    "questionTag": { "type": "string", "default": "h3" },
    "showQuestionMarker": { "type": "boolean", "default": true },
    "colorMode": { "type": "string", "default": "inherit" },
    "accentColor": { "type": "string", "default": "" },
    "questionBgColor": { "type": "string", "default": "" },
    "markerTextColor": { "type": "string", "default": "" }
  },
  "editorScript": "modfarm-interview-qa-editor",
  "style": "file:./style.css",
  "editorStyle": "file:./style.css"
}
