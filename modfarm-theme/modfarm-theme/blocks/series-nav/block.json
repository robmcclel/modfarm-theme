{
  "apiVersion": 2,
  "name": "modfarm/series-nav",
  "title": "Series Previous/Next",
  "category": "modfarm-theme",
  "icon": "controls-forward",
  "description": "Prev/Next buttons that stay inside the current book's series with selectable order mode.",
  "keywords": ["book", "series", "navigation", "prev", "next"],
  "supports": { "html": false, "align": false },

  "attributes": {
    "mode": { "type": "string", "default": "position" },
    "prevLabel": { "type": "string", "default": "« Previous" },
    "nextLabel": { "type": "string", "default": "Next »" },

    "showSeriesLabel": { "type": "boolean", "default": true },

    "fontSizePx": { "type": "number", "default": 0 },

    "textColor": { "type": "string", "default": "" },
    "linkColor": { "type": "string", "default": "" },

    "context": { "type": "object", "default": {} }
  },

  "editorScript": "modfarm-series-nav-editor",
  "style": "file:./style.css",
  "editorStyle": "file:./editor.css"
}